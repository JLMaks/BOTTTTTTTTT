<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>République RP — Créateur de Personnage</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --gold:#c9a84c;--gold-l:#f0d080;--gold-d:#9a7a2e;
  --ink:#060606;--parch:#f0e8d5;
  --red:#7a1010;--blue:#111e3a;
  --panel:#0c0c0cee;--border:#c9a84c2a;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--ink);font-family:'Crimson Text',serif;color:var(--parch);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;z-index:0;
  background:radial-gradient(ellipse 60% 40% at 15% 0%,#1a2e5a20,transparent),
    radial-gradient(ellipse 60% 40% at 85% 100%,#6a0f0f15,transparent),
    repeating-linear-gradient(0deg,transparent 0,transparent 79px,#c9a84c06 79px,#c9a84c06 80px),
    repeating-linear-gradient(90deg,transparent 0,transparent 79px,#c9a84c06 79px,#c9a84c06 80px);
  pointer-events:none}
.app{position:relative;z-index:1;display:flex;flex-direction:column;min-height:100vh}
header{text-align:center;padding:26px 20px 18px;border-bottom:1px solid var(--border);position:relative}
header::before,header::after{content:'⚜';position:absolute;top:50%;transform:translateY(-50%);font-size:20px;color:var(--gold);opacity:.35}
header::before{left:28px}header::after{right:28px}
.site-title{font-family:'Playfair Display',serif;font-size:clamp(22px,4vw,46px);font-weight:900;letter-spacing:5px;text-transform:uppercase;color:var(--gold-l);text-shadow:0 0 60px #c9a84c44;line-height:1}
.site-sub{font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:8px;color:var(--gold);opacity:.55;margin-top:6px;text-transform:uppercase}
.workspace{flex:1;display:grid;grid-template-columns:310px 1fr 295px;gap:14px;padding:14px;max-width:1440px;width:100%;margin:0 auto}
@media(max-width:1080px){.workspace{grid-template-columns:270px 1fr 270px}}
@media(max-width:820px){.workspace{grid-template-columns:1fr}}
.panel{background:var(--panel);border:1px solid var(--border);border-radius:2px;padding:16px;position:relative;backdrop-filter:blur(8px)}
.panel::after{content:'';position:absolute;top:5px;left:5px;right:5px;bottom:5px;border:1px solid #c9a84c11;border-radius:1px;pointer-events:none}
.ph{font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:6px;text-transform:uppercase;color:var(--gold);padding-bottom:11px;margin-bottom:13px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.ph::before{content:'▸';opacity:.5}
.tabs{display:flex;gap:1px;margin-bottom:13px;border-bottom:1px solid var(--border)}
.tb{background:none;border:none;border-bottom:2px solid transparent;font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;padding:7px 11px;cursor:pointer;color:var(--gold);opacity:.4;transition:opacity .2s}
.tb.on{opacity:1;border-bottom-color:var(--gold)}
.tp{display:none}.tp.on{display:block}
.f{margin-bottom:11px}
.f label{display:block;font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);opacity:.7;margin-bottom:5px}
.f input[type=text],.f select,.f textarea{width:100%;background:#070707;border:1px solid #c9a84c2a;color:var(--parch);padding:8px 10px;font-family:'Crimson Text',serif;font-size:15px;outline:none;border-radius:1px;transition:border-color .2s}
.f input:focus,.f select:focus,.f textarea:focus{border-color:var(--gold)}
.f select option{background:#0e0e0e}
.f textarea{resize:vertical;min-height:64px;line-height:1.55}
.sws{display:flex;flex-wrap:wrap;gap:5px;margin-top:4px}
.sw{width:25px;height:25px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .13s,border-color .13s;flex-shrink:0}
.sw:hover{transform:scale(1.2)}.sw.on{border-color:var(--gold-l);box-shadow:0 0 7px var(--gold)}
input[type=range]{-webkit-appearance:none;height:3px;outline:none;background:linear-gradient(to right,var(--gold) 0%,var(--gold) var(--pct,50%),#1a1a1a var(--pct,50%),#1a1a1a 100%);cursor:pointer;border-radius:2px}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--gold);box-shadow:0 0 5px var(--gold)}
.iw{display:flex;align-items:center;gap:8px;margin-top:4px}
.il{font-family:'Courier Prime',monospace;font-size:8px;letter-spacing:2px;color:var(--gold);opacity:.5;width:44px;flex-shrink:0}
.il:last-child{text-align:right}
.sr{display:flex;align-items:center;gap:7px;margin-bottom:8px}
.sn{font-family:'Courier Prime',monospace;font-size:8px;letter-spacing:2px;color:var(--gold);opacity:.6;width:76px;flex-shrink:0}
.sb{flex:1;height:3px;background:#1a1a1a;border-radius:2px;overflow:hidden}
.sf{height:100%;background:linear-gradient(90deg,var(--gold-d),var(--gold-l));border-radius:2px;transition:width .32s ease}
.sv{font-family:'Courier Prime',monospace;font-size:9px;color:var(--gold-l);width:20px;text-align:right;flex-shrink:0}
.pts{font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:2px;color:var(--gold);opacity:.45;margin-top:7px}
.pts span{color:var(--gold-l);font-weight:700}
.vc{display:flex;flex-direction:column;gap:13px}
#vw{background:radial-gradient(ellipse at 30% 10%,#0a1a0a,#060806 70%);border:1px solid var(--gold);border-radius:2px;position:relative;overflow:hidden;aspect-ratio:.82;min-height:460px}
#tc{width:100%!important;height:100%!important;display:block}
.vcc{position:absolute;width:17px;height:17px;border-color:var(--gold);border-style:solid;opacity:.45}
.vcc.tl{top:9px;left:9px;border-width:1px 0 0 1px}.vcc.tr{top:9px;right:9px;border-width:1px 1px 0 0}
.vcc.bl{bottom:9px;left:9px;border-width:0 0 1px 1px}.vcc.br{bottom:9px;right:9px;border-width:0 1px 1px 0}
.vlbl{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,#00000099);padding:18px 13px 11px;font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:4px;color:var(--gold);opacity:.55;text-align:center;text-transform:uppercase}
.vhint{position:absolute;top:11px;right:13px;font-family:'Courier Prime',monospace;font-size:8px;letter-spacing:2px;color:var(--gold);opacity:.3}
.cp{background:linear-gradient(150deg,#0a0e1a,#08080a);border:1px solid var(--gold);padding:17px;border-radius:2px;position:relative;overflow:hidden}
.cp::after{content:'⚜';position:absolute;bottom:-14px;right:-8px;font-size:88px;color:var(--gold);opacity:.04;pointer-events:none}
.cnm{font-family:'Playfair Display',serif;font-size:21px;font-weight:700;color:var(--gold-l)}
.cti{font-family:'Crimson Text',serif;font-style:italic;font-size:13px;opacity:.62;margin-top:2px}
.cdv{height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:11px 0}
.cbio{font-size:13px;line-height:1.65;opacity:.72;font-style:italic}
.cmeta{display:flex;gap:15px;margin-top:9px;font-family:'Courier Prime',monospace;font-size:9px;color:var(--gold);opacity:.5;letter-spacing:2px}
.pb{display:inline-flex;align-items:center;gap:6px;padding:5px 11px;border-radius:2px;font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;border:1px solid currentColor;margin-top:5px}
.dbox{background:#0a0a14;border:1px solid #5865F21a;border-radius:4px;padding:11px;font-family:'Courier Prime',monospace;font-size:11px;color:#c9c9dd;white-space:pre-wrap;line-height:1.7;max-height:205px;overflow-y:auto}
.dbox::-webkit-scrollbar{width:3px}.dbox::-webkit-scrollbar-thumb{background:var(--gold-d)}
.btn{font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:4px;text-transform:uppercase;padding:9px 16px;border:1px solid;cursor:pointer;transition:all .2s;background:transparent;border-radius:1px;display:inline-flex;align-items:center;gap:6px}
.bg{border-color:var(--gold);color:var(--gold)}.bg:hover{background:var(--gold);color:var(--ink)}
.bb{border-color:#2a4a8a;color:#6a9add}.bb:hover{background:var(--blue);color:#fff}
.br{border-color:#5a1010;color:#cc4444}.br:hover{background:var(--red);color:#fff}
.bfull{width:100%;justify-content:center;margin-top:7px}
.brow{display:flex;gap:7px;flex-wrap:wrap;margin-top:11px}
.sl{display:flex;flex-direction:column;gap:5px;max-height:170px;overflow-y:auto}
.si{display:flex;align-items:center;justify-content:space-between;padding:7px 10px;background:#090909;border:1px solid #c9a84c18;cursor:pointer;transition:border-color .2s;border-radius:1px}
.si:hover{border-color:var(--gold)}
.snm{font-family:'Playfair Display',serif;font-size:13px;color:var(--gold-l)}
.sti{font-family:'Courier Prime',monospace;font-size:8px;letter-spacing:2px;color:var(--gold);opacity:.45}
.it{position:relative;height:6px;border-radius:3px;background:linear-gradient(to right,#8b1a1a,#444,#1a2e5a);margin:7px 0}
.ic{position:absolute;top:-5px;width:16px;height:16px;background:var(--gold);border-radius:50%;transform:translateX(-50%);box-shadow:0 0 8px var(--gold);left:50%;transition:left .3s}
.ie{display:flex;justify-content:space-between;font-family:'Courier Prime',monospace;font-size:8px;color:var(--gold);opacity:.3;letter-spacing:2px}
.ibig{font-family:'Playfair Display',serif;font-size:19px;color:var(--gold-l);margin:5px 0}
.toast{position:fixed;bottom:26px;left:50%;transform:translateX(-50%) translateY(100px);background:var(--gold);color:var(--ink);padding:10px 21px;font-family:'Courier Prime',monospace;font-size:10px;letter-spacing:4px;text-transform:uppercase;transition:transform .3s ease;z-index:9999;border-radius:1px;white-space:nowrap}
.toast.show{transform:translateX(-50%) translateY(0)}
.guide p{margin-bottom:9px;font-size:13px;line-height:1.75;opacity:.68}
.guide strong{font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:3px;color:var(--gold);opacity:1;display:block;margin-bottom:2px}
code{background:#111;padding:1px 5px;font-family:'Courier Prime',monospace;color:var(--gold);font-size:11px}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:#080808}::-webkit-scrollbar-thumb{background:var(--gold-d);border-radius:2px}
</style>
</head>
<body>
<div class="app">
<header>
  <div class="site-sub">République Discord — Roleplay Politique</div>
  <h1 class="site-title">Créateur de Personnage</h1>
  <div class="site-sub" style="letter-spacing:10px;margin-top:5px">Édition Officielle</div>
</header>

<div class="workspace">

<!-- ══ LEFT ══ -->
<div style="display:flex;flex-direction:column;gap:13px">

<div class="panel">
  <div class="ph">Identité & Parti</div>
  <div class="tabs">
    <button class="tb on" onclick="tab(event,'id')">Identité</button>
    <button class="tb" onclick="tab(event,'pt')">Parti</button>
  </div>
  <div class="tp on" id="tab-id">
    <div class="f"><label>Prénom & Nom</label><input type="text" id="cn" placeholder="Henri de Montfort" oninput="prev()"></div>
    <div class="f"><label>Titre / Fonction</label><input type="text" id="ct" placeholder="Sénateur — 3e Circonscription" oninput="prev()"></div>
    <div class="f"><label>Région</label><input type="text" id="cr" placeholder="Île-de-France, Paris 8e" oninput="prev()"></div>
    <div class="f"><label>Âge</label><input type="text" id="ca" placeholder="47 ans" oninput="prev()"></div>
    <div class="f"><label>Biographie</label><textarea id="cb" placeholder="Ancien avocat, élu depuis 2019…" oninput="prev()"></textarea></div>
    <div class="f"><label>Axe Idéologique</label>
      <div class="iw"><span class="il">GAUCHE</span><input type="range" id="ci" min="0" max="100" value="50" oninput="onIdeo(this)"><span class="il">DROITE</span></div>
    </div>
  </div>
  <div class="tp" id="tab-pt">
    <div class="f"><label>Parti Politique</label>
      <select id="cp2" onchange="onParty()">
        <option value="none">— Indépendant —</option>
        <optgroup label="Gauche">
          <option value="far-left">🔴 Front Révolutionnaire</option>
          <option value="left">🌹 Parti Socialiste Uni</option>
          <option value="green">🌿 Mouvement Écologiste</option>
        </optgroup>
        <optgroup label="Centre">
          <option value="center-left">🕊️ Alliance Progressiste</option>
          <option value="center">⚖️ Parti du Centre</option>
          <option value="center-right">🏛️ Union Républicaine</option>
        </optgroup>
        <optgroup label="Droite">
          <option value="right">🦅 Rassemblement National-Conservateur</option>
          <option value="far-right">⚔️ Mouvement Souverainiste</option>
          <option value="liberal">💼 Parti Libéral</option>
        </optgroup>
        <optgroup label="Autre"><option value="custom">✦ Parti Personnalisé</option></optgroup>
      </select>
    </div>
    <div class="f" id="cpf" style="display:none"><label>Nom du parti</label><input type="text" id="cpn" placeholder="Mon Parti" oninput="prev()"></div>
    <div id="pp" style="margin-top:8px"></div>
  </div>
</div>

<div class="panel">
  <div class="ph">Sauvegardés</div>
  <div class="sl" id="sl"><div style="font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:3px;color:var(--gold);opacity:.25;text-align:center;padding:16px;text-transform:uppercase">Aucun personnage</div></div>
  <div class="brow">
    <button class="btn bg" onclick="saveLocal()">💾 Sauvegarder</button>
    <button class="btn bb" onclick="expJSON()">📤 JSON</button>
    <label class="btn bb" style="cursor:pointer">📥 Import<input type="file" accept=".json" onchange="impJSON(event)" style="display:none"></label>
  </div>
</div>
</div>

<!-- ══ CENTER ══ -->
<div class="vc">
<div class="panel" style="padding:0;overflow:hidden;border-color:var(--gold)">
  <div class="ph" style="padding:13px 16px;margin:0">Modèle 3D Réaliste</div>

  <div style="padding:0 13px 11px;display:grid;grid-template-columns:1fr 1fr;gap:9px">
    <div class="f" style="margin:0"><label>Peau</label><div class="sws" id="sw-skin">
      <div class="sw on" style="background:#f5c9a0" data-c="#f5c9a0" onclick="sw(this,'skin')"></div>
      <div class="sw" style="background:#e8a87c" data-c="#e8a87c" onclick="sw(this,'skin')"></div>
      <div class="sw" style="background:#d4865a" data-c="#d4865a" onclick="sw(this,'skin')"></div>
      <div class="sw" style="background:#b06030" data-c="#b06030" onclick="sw(this,'skin')"></div>
      <div class="sw" style="background:#804020" data-c="#804020" onclick="sw(this,'skin')"></div>
      <div class="sw" style="background:#4a2010" data-c="#4a2010" onclick="sw(this,'skin')"></div>
    </div></div>
    <div class="f" style="margin:0"><label>Cheveux</label><div class="sws" id="sw-hair">
      <div class="sw on" style="background:#18080a" data-c="#18080a" onclick="sw(this,'hair')"></div>
      <div class="sw" style="background:#3a1c08" data-c="#3a1c08" onclick="sw(this,'hair')"></div>
      <div class="sw" style="background:#7a4200" data-c="#7a4200" onclick="sw(this,'hair')"></div>
      <div class="sw" style="background:#c07818" data-c="#c07818" onclick="sw(this,'hair')"></div>
      <div class="sw" style="background:#d8c890" data-c="#d8c890" onclick="sw(this,'hair')"></div>
      <div class="sw" style="background:#dcdcdc" data-c="#dcdcdc" onclick="sw(this,'hair')"></div>
      <div class="sw" style="background:#b02515" data-c="#b02515" onclick="sw(this,'hair')"></div>
    </div></div>
    <div class="f" style="margin:0"><label>Costume</label><div class="sws" id="sw-outfit">
      <div class="sw on" style="background:#10141e" data-c="#10141e" onclick="sw(this,'outfit')"></div>
      <div class="sw" style="background:#1a0c0c" data-c="#1a0c0c" onclick="sw(this,'outfit')"></div>
      <div class="sw" style="background:#0c1a0c" data-c="#0c1a0c" onclick="sw(this,'outfit')"></div>
      <div class="sw" style="background:#1a160a" data-c="#1a160a" onclick="sw(this,'outfit')"></div>
      <div class="sw" style="background:#080808" data-c="#080808" onclick="sw(this,'outfit')"></div>
      <div class="sw" style="background:#d4d4d4" data-c="#d4d4d4" onclick="sw(this,'outfit')"></div>
    </div></div>
    <div class="f" style="margin:0"><label>Cravate</label><div class="sws" id="sw-tie">
      <div class="sw on" style="background:#7a1010" data-c="#7a1010" onclick="sw(this,'tie')"></div>
      <div class="sw" style="background:#0a1a5a" data-c="#0a1a5a" onclick="sw(this,'tie')"></div>
      <div class="sw" style="background:#0a4a0a" data-c="#0a4a0a" onclick="sw(this,'tie')"></div>
      <div class="sw" style="background:#c9a84c" data-c="#c9a84c" onclick="sw(this,'tie')"></div>
      <div class="sw" style="background:#7a7a7a" data-c="#7a7a7a" onclick="sw(this,'tie')"></div>
    </div></div>
  </div>

  <div style="padding:0 13px 11px;display:grid;grid-template-columns:1fr 1fr;gap:9px">
    <div class="f" style="margin:0"><label>Morphologie</label>
      <select id="cbuild" onchange="rebuild()"><option value="slim">Élancé</option><option value="average" selected>Standard</option><option value="stocky">Corpulent</option><option value="athletic">Athlétique</option></select>
    </div>
    <div class="f" style="margin:0"><label>Accessoire</label>
      <select id="cacc" onchange="rebuild()"><option value="none">— Aucun —</option><option value="glasses">Lunettes</option><option value="tophat">Haut-de-forme</option><option value="medal">Médaille</option><option value="scarf">Écharpe tricolore</option><option value="beard">Barbe</option><option value="mustache">Moustache</option></select>
    </div>
  </div>

  <div id="vw">
    <canvas id="tc"></canvas>
    <div class="vcc tl"></div><div class="vcc tr"></div><div class="vcc bl"></div><div class="vcc br"></div>
    <div class="vhint">🖱 GLISSER · 🔍 MOLETTE</div>
    <div class="vlbl">MODÈLE 3D — PERSONNAGE RP</div>
  </div>
</div>

<div class="cp">
  <div class="cnm" id="pnm">Henri de Montfort</div>
  <div class="cti" id="pti">Sénateur — 3e Circonscription</div>
  <div id="pbdg"></div>
  <div class="cdv"></div>
  <div class="cbio" id="pbio">Votre biographie...</div>
  <div class="cmeta"><span id="preg">📍 —</span><span id="page">🎂 —</span></div>
</div>
</div>

<!-- ══ RIGHT ══ -->
<div style="display:flex;flex-direction:column;gap:13px">

<div class="panel">
  <div class="ph">Compétences</div>
  <div id="sui"></div>
  <div class="pts">Restants : <span id="pts">15</span> / 15</div>
</div>

<div class="panel">
  <div class="ph">Idéologie</div>
  <div style="font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:3px;color:var(--gold);opacity:.5">POSITION</div>
  <div class="ibig" id="itxt">Centre</div>
  <div class="it"><div class="ic" id="ic"></div></div>
  <div class="ie"><span>GAUCHE</span><span>DROITE</span></div>
</div>

<div class="panel">
  <div class="ph">Export Discord</div>
  <div class="dbox" id="dout">Remplissez le formulaire...</div>
  <button class="btn bg bfull" onclick="copyDisc()">📋 Copier la fiche</button>
</div>

<div class="panel" id="ssp" style="display:none">
  <div class="ph">Enregistrer sur Discord</div>
  <p style="font-size:13px;opacity:.68;margin-bottom:9px">Sauvegardez sur le serveur Discord.</p>
  <button class="btn bg bfull" onclick="saveServer()">✅ Confirmer</button>
</div>

<div class="panel guide">
  <div class="ph">Guide</div>
  <p><strong>1. CRÉER</strong>Remplissez Identité, Parti et Compétences.</p>
  <p><strong>2. MODÈLE</strong>Personnalisez l'avatar 3D, faites-le tourner.</p>
  <p><strong>3. DISCORD</strong>Copiez entre <code>```</code> dans Discord.</p>
  <p><strong>4. SAUVER</strong>Bouton "Sauvegarder" ou exportez en JSON.</p>
</div>
</div>
</div>
</div>
<div class="toast" id="toast"></div>

<!-- ══════════════════ THREE.JS ══════════════════ -->
<script>
const canvas=document.getElementById('tc'),vw=document.getElementById('vw');
const R=new THREE.WebGLRenderer({canvas,antialias:true,alpha:false});
R.setPixelRatio(Math.min(devicePixelRatio,2));
R.shadowMap.enabled=true;R.shadowMap.type=THREE.PCFSoftShadowMap;
R.toneMapping=THREE.ACESFilmicToneMapping;R.toneMappingExposure=1.15;

const scene=new THREE.Scene();
scene.background=new THREE.Color(0x050a05);
scene.fog=new THREE.FogExp2(0x050a05,0.2);

const cam=new THREE.PerspectiveCamera(42,1,0.1,50);
cam.position.set(0,0.85,3.9);cam.lookAt(0,0.6,0);

// Lights
scene.add(new THREE.AmbientLight(0x3a3a5a,0.55));
const kl=new THREE.DirectionalLight(0xfff0d0,2.2);
kl.position.set(3,6,4);kl.castShadow=true;
kl.shadow.mapSize.set(2048,2048);kl.shadow.bias=-0.001;
['left','right','top','bottom'].forEach(k=>kl.shadow.camera[k]=k==='left'||k==='bottom'?-4:4);
scene.add(kl);
const fl=new THREE.DirectionalLight(0x304080,0.55);fl.position.set(-4,2,-2);scene.add(fl);
const rl=new THREE.DirectionalLight(0xc9a84c,1.0);rl.position.set(0,4,-5);scene.add(rl);
scene.add(new THREE.HemisphereLight(0x203020,0x080808,0.28));

// Floor
const floor=new THREE.Mesh(new THREE.PlaneGeometry(10,10),new THREE.MeshStandardMaterial({color:0x080808,roughness:0.9,metalness:0.1}));
floor.rotation.x=-Math.PI/2;floor.position.y=-1.08;floor.receiveShadow=true;scene.add(floor);
const glow=new THREE.Mesh(new THREE.CircleGeometry(0.65,32),new THREE.MeshBasicMaterial({color:0xc9a84c,transparent:true,opacity:0.07}));
glow.rotation.x=-Math.PI/2;glow.position.y=-1.06;scene.add(glow);

// Colors
const C={skin:new THREE.Color('#f5c9a0'),hair:new THREE.Color('#18080a'),outfit:new THREE.Color('#10141e'),tie:new THREE.Color('#7a1010')};

const CG=new THREE.Group();scene.add(CG);

function mat(color,rough=0.8,metal=0,side=THREE.FrontSide){return new THREE.MeshStandardMaterial({color,roughness:rough,metalness:metal,side})}

function buildChar(){
  CG.clear();
  const bt=document.getElementById('cbuild')?.value||'average';
  const acc=document.getElementById('cacc')?.value||'none';
  const bp={slim:{sw:0.78,sh:1.0,aw:0.85,lw:0.85},average:{sw:1,sh:1,aw:1,lw:1},stocky:{sw:1.18,sh:0.93,aw:1.14,lw:1.12},athletic:{sw:1.08,sh:1.02,aw:1.1,lw:1.0}}[bt]||{sw:1,sh:1,aw:1,lw:1};

  function add(m,cast=true){if(cast)m.castShadow=true;CG.add(m);return m;}
  const SM=()=>mat(C.skin.clone());
  const HM=()=>mat(C.hair.clone(),0.95);
  const OM=()=>mat(C.outfit.clone(),0.72,0.06);
  const TM=()=>mat(C.tie.clone(),0.8);
  const WM=()=>mat(0xf4f0e8,0.9);
  const XM=()=>mat(0x0e0a06,0.55,0.12);
  const EM=()=>mat(0x0a0808,0.2);
  const ScM=()=>mat(0xf5f0ea,0.88);
  const IrM=()=>mat(0x2a4060,0.3);

  // TORSO — jacket with revers
  const torso=add(new THREE.Mesh(new THREE.BoxGeometry(0.64*bp.sw,0.74*bp.sh,0.33),OM()));
  torso.position.set(0,0.14,0);

  // Shirt front
  const shirt=add(new THREE.Mesh(new THREE.BoxGeometry(0.17,0.7*bp.sh,0.34),WM()));
  shirt.position.set(0,0.14,0);

  // Tie
  const tie=add(new THREE.Mesh(new THREE.BoxGeometry(0.072,0.45*bp.sh,0.345),TM()));
  tie.position.set(0,0.08,0);

  // Belt
  const belt=add(new THREE.Mesh(new THREE.BoxGeometry(0.65*bp.sw,0.058,0.34),mat(0x0a0806,0.6,0.2)));
  belt.position.set(0,-0.23,0);
  const buckle=add(new THREE.Mesh(new THREE.BoxGeometry(0.072,0.05,0.345),mat(0xb0882a,0.25,0.9)));
  buckle.position.set(0,-0.23,0);

  // Pocket square
  add(new THREE.Mesh(new THREE.BoxGeometry(0.07,0.065,0.34),mat(0xf8f4e8,0.9))).position.set(-0.22*bp.sw,0.38,0);

  // Shoulders
  [-1,1].forEach(s=>{
    const sh=add(new THREE.Mesh(new THREE.SphereGeometry(0.185*bp.aw,12,12,0,Math.PI*2,0,Math.PI*.55),OM()));
    sh.position.set(s*0.38*bp.sw,0.5,0);
  });

  // Upper arms
  [-1,1].forEach(s=>{
    const ua=add(new THREE.Mesh(new THREE.CylinderGeometry(0.1*bp.aw,0.095*bp.aw,0.44,10),OM()));
    ua.position.set(s*0.44*bp.sw,0.22,0);ua.rotation.z=s*0.12;
  });

  // Forearms
  [-1,1].forEach(s=>{
    const fa=add(new THREE.Mesh(new THREE.CylinderGeometry(0.083*bp.aw,0.076*bp.aw,0.39,10),OM()));
    fa.position.set(s*0.47*bp.sw,-0.16,0);fa.rotation.z=s*0.14;
    const cuff=add(new THREE.Mesh(new THREE.CylinderGeometry(0.085,0.085,0.068,10),WM()));
    cuff.position.set(s*0.49*bp.sw,-0.31,0);
  });

  // Hands — palm + fingers
  [-1,1].forEach(s=>{
    const palm=add(new THREE.Mesh(new THREE.BoxGeometry(0.1,0.13,0.072),SM()));
    palm.position.set(s*0.51*bp.sw,-0.43,0);
    const thumb=add(new THREE.Mesh(new THREE.CylinderGeometry(0.022,0.017,0.08,6),SM()));
    thumb.position.set(s*(0.47*bp.sw),-0.45,0.04);thumb.rotation.z=s*0.9;
    [-1.5,-0.5,0.5,1.5].forEach(f=>{
      const fg=add(new THREE.Mesh(new THREE.CylinderGeometry(0.017,0.013,0.078,5),SM()));
      fg.position.set(s*(0.485*bp.sw)+f*0.022,-0.51,0);
    });
  });

  // Neck
  const neck=add(new THREE.Mesh(new THREE.CylinderGeometry(0.088,0.105,0.2,10),SM()));
  neck.position.set(0,0.63,0);

  // HEAD — realistic proportions
  const head=add(new THREE.Mesh(new THREE.SphereGeometry(0.265,22,18),SM()));
  head.scale.set(0.9,1.06,0.94);head.position.set(0,0.96,0);

  // Jaw
  const jaw=add(new THREE.Mesh(new THREE.SphereGeometry(0.225,18,12,0,Math.PI*2,Math.PI*.48,Math.PI*.55),SM()));
  jaw.scale.set(0.92,0.87,0.88);jaw.position.set(0,0.74,0);

  // Forehead ridge
  const fore=add(new THREE.Mesh(new THREE.SphereGeometry(0.19,10,8,0,Math.PI*2,0,Math.PI*.3),SM()));
  fore.position.set(0,1.1,0.19);fore.scale.set(1,0.38,0.58);

  // Cheekbones
  [-1,1].forEach(s=>{
    const ck=add(new THREE.Mesh(new THREE.SphereGeometry(0.11,8,8),SM()));
    ck.scale.set(0.68,0.48,0.38);ck.position.set(s*0.175,0.94,0.21);
  });

  // EYES — full construction
  [-1,1].forEach(s=>{
    // Socket
    const sock=new THREE.Mesh(new THREE.SphereGeometry(0.057,8,8),mat(C.skin.clone().multiplyScalar(0.65),1));
    sock.position.set(s*0.09,0.98,0.22);sock.scale.set(1.22,0.88,0.5);add(sock);
    // Eyeball
    const eye=add(new THREE.Mesh(new THREE.SphereGeometry(0.048,12,12),ScM()));
    eye.position.set(s*0.09,0.98,0.235);
    // Iris
    const iri=add(new THREE.Mesh(new THREE.CircleGeometry(0.03,12),IrM()));
    iri.position.set(s*0.09,0.98,0.282);
    // Pupil
    const pup=add(new THREE.Mesh(new THREE.CircleGeometry(0.016,10),EM()));
    pup.position.set(s*0.09,0.98,0.2825);
    // Upper eyelid
    const lid=add(new THREE.Mesh(new THREE.SphereGeometry(0.05,8,4,0,Math.PI*2,0,Math.PI*.38),SM()));
    lid.position.set(s*0.09,1.005,0.237);lid.rotation.x=0.42;
    // Eyebrow
    const brow=add(new THREE.Mesh(new THREE.BoxGeometry(0.094,0.019,0.01),HM()));
    brow.position.set(s*0.09,1.04,0.248);brow.rotation.z=s*0.14;
  });

  // NOSE
  const nosB=add(new THREE.Mesh(new THREE.SphereGeometry(0.04,8,6),SM()));
  nosB.scale.set(1.42,0.78,1.02);nosB.position.set(0,0.948,0.268);
  const nosBr=add(new THREE.Mesh(new THREE.BoxGeometry(0.028,0.095,0.025),SM()));
  nosBr.position.set(0,0.992,0.258);
  [-1,1].forEach(s=>{
    const nos=add(new THREE.Mesh(new THREE.SphereGeometry(0.024,6,6),SM()));
    nos.scale.set(1,0.68,0.78);nos.position.set(s*0.031,0.944,0.268);
  });

  // MOUTH
  const ulip=add(new THREE.Mesh(new THREE.SphereGeometry(0.062,8,4,0,Math.PI*2,0,Math.PI*.5),SM()));
  ulip.scale.set(1.2,0.48,0.68);ulip.position.set(0,0.907,0.26);
  const llip=add(new THREE.Mesh(new THREE.SphereGeometry(0.066,8,6),SM()));
  llip.scale.set(1.1,0.38,0.58);llip.position.set(0,0.892,0.258);
  const mline=add(new THREE.Mesh(new THREE.BoxGeometry(0.082,0.008,0.01),mat(C.skin.clone().multiplyScalar(0.58),1)));
  mline.position.set(0,0.9,0.266);

  // EARS
  [-1,1].forEach(s=>{
    const ear=add(new THREE.Mesh(new THREE.SphereGeometry(0.068,8,8),SM()));
    ear.scale.set(0.44,0.76,0.48);ear.position.set(s*0.264,0.952,0);
  });

  // HAIR cap + sides
  const hcap=add(new THREE.Mesh(new THREE.SphereGeometry(0.275,20,14,0,Math.PI*2,0,Math.PI*.53),HM()));
  hcap.position.set(0,0.96,-0.01);hcap.scale.set(0.94,1.0,0.95);
  [-1,1].forEach(s=>{
    const sh=add(new THREE.Mesh(new THREE.SphereGeometry(0.185,10,8),HM()));
    sh.scale.set(0.44,0.7,0.58);sh.position.set(s*0.252,0.935,0.02);
  });

  // LEGS — thighs + calves
  [-1,1].forEach(s=>{
    const thi=add(new THREE.Mesh(new THREE.CylinderGeometry(0.118*bp.lw,0.108*bp.lw,0.49,10),OM()));
    thi.position.set(s*0.175*bp.sw,-0.55,0);
    const calf=add(new THREE.Mesh(new THREE.CylinderGeometry(0.097*bp.lw,0.083*bp.lw,0.44,10),OM()));
    calf.position.set(s*0.175*bp.sw,-0.99,0);
  });

  // SHOES — detailed
  [-1,1].forEach(s=>{
    const shoe=add(new THREE.Mesh(new THREE.BoxGeometry(0.138*bp.lw,0.09,0.33),XM()));
    shoe.position.set(s*0.175*bp.sw,-1.2,0.04);
    const toecap=add(new THREE.Mesh(new THREE.SphereGeometry(0.078*bp.lw,8,6,0,Math.PI*2,0,Math.PI*.65),XM()));
    toecap.scale.set(0.84,0.58,0.78);toecap.position.set(s*0.175*bp.sw,-1.2,0.2);toecap.rotation.x=-Math.PI*0.3;
    const heel=add(new THREE.Mesh(new THREE.BoxGeometry(0.125*bp.lw,0.1,0.1),XM()));
    heel.position.set(s*0.175*bp.sw,-1.23,-0.12);
    const sole=add(new THREE.Mesh(new THREE.BoxGeometry(0.145*bp.lw,0.024,0.33),mat(0x1a1210,0.8)));
    sole.position.set(s*0.175*bp.sw,-1.255,0.04);
  });

  // ── ACCESSORIES ──
  if(acc==='glasses'){
    const gm=mat(0x0c0808,0.4,0.7);
    const lm=mat(0x203050,0.1,0,THREE.FrontSide);lm.transparent=true;lm.opacity=0.38;
    [-1,1].forEach(s=>{
      const fr=add(new THREE.Mesh(new THREE.TorusGeometry(0.072,0.009,6,14),gm),false);
      fr.position.set(s*0.09,0.98,0.273);fr.rotation.y=Math.PI/2;
      const ln=add(new THREE.Mesh(new THREE.CircleGeometry(0.064,12),lm),false);
      ln.position.set(s*0.09,0.98,0.271);
    });
    const br=add(new THREE.Mesh(new THREE.CylinderGeometry(0.005,0.005,0.04,5),gm),false);
    br.position.set(0,0.98,0.271);br.rotation.z=Math.PI/2;
  }else if(acc==='tophat'){
    const hm=mat(0x080505,0.68);
    const brim=add(new THREE.Mesh(new THREE.CylinderGeometry(0.35,0.35,0.028,18),hm));brim.position.set(0,1.22,0);
    const top=add(new THREE.Mesh(new THREE.CylinderGeometry(0.198,0.218,0.43,18),hm));top.position.set(0,1.455,0);
    const band=add(new THREE.Mesh(new THREE.CylinderGeometry(0.22,0.22,0.05,18),mat(0xc9a84c,0.55,0.4)));band.position.set(0,1.26,0);
  }else if(acc==='medal'){
    const med=add(new THREE.Mesh(new THREE.CylinderGeometry(0.067,0.067,0.018,14),mat(0xd4a820,0.18,0.95)));
    med.position.set(-0.21*bp.sw,0.4,0.18);med.rotation.x=Math.PI/2;
    const rib=add(new THREE.Mesh(new THREE.BoxGeometry(0.032,0.1,0.01),mat(0x8b1a1a,0.9)));
    rib.position.set(-0.21*bp.sw,0.48,0.18);
  }else if(acc==='scarf'){
    const sm=mat(0x0033aa,0.9);
    add(new THREE.Mesh(new THREE.BoxGeometry(0.52*bp.sw,0.04,0.065),sm)).position.set(0,0.6,0.12);
    add(new THREE.Mesh(new THREE.BoxGeometry(0.042,0.2,0.042),sm)).position.set(0.13*bp.sw,0.47,0.12);
  }else if(acc==='beard'){
    const bm=mat(C.hair.clone(),0.98);
    const b=add(new THREE.Mesh(new THREE.SphereGeometry(0.195,12,10,0,Math.PI*2,Math.PI*.53,Math.PI*.5),bm));
    b.scale.set(0.94,0.84,0.88);b.position.set(0,0.86,0.04);
  }else if(acc==='mustache'){
    const mm=mat(C.hair.clone(),0.98);
    const mu=add(new THREE.Mesh(new THREE.SphereGeometry(0.08,8,6,0,Math.PI*2,Math.PI*.4,Math.PI*.35),mm));
    mu.scale.set(1.6,0.5,0.7);mu.position.set(0,0.918,0.263);
  }

  CG.position.y=0.1;
}

// RESIZE
function resize(){
  const w=vw.clientWidth,h=vw.clientHeight;
  R.setSize(w,h,false);cam.aspect=w/h;cam.updateProjectionMatrix();
}
new ResizeObserver(resize).observe(vw);resize();

// ANIMATE
let T=0,AR=true;
(function loop(){
  requestAnimationFrame(loop);T+=0.016;
  if(AR) CG.rotation.y+=0.006;
  CG.position.y=0.1+Math.sin(T*1.1)*0.008+Math.sin(T*.55)*0.003;
  R.render(scene,cam);
})();

// DRAG
let drag=false,px=0;
vw.addEventListener('mousedown',e=>{drag=true;AR=false;px=e.clientX});
vw.addEventListener('touchstart',e=>{drag=true;AR=false;px=e.touches[0].clientX});
window.addEventListener('mousemove',e=>{if(!drag)return;CG.rotation.y+=(e.clientX-px)*.012;px=e.clientX});
window.addEventListener('touchmove',e=>{if(!drag)return;CG.rotation.y+=(e.touches[0].clientX-px)*.012;px=e.touches[0].clientX});
window.addEventListener('mouseup',()=>drag=false);window.addEventListener('touchend',()=>drag=false);
vw.addEventListener('wheel',e=>{cam.position.z+=e.deltaY*.003;cam.position.z=Math.max(1.6,Math.min(6.5,cam.position.z));e.preventDefault()},{passive:false});

// COLOR SWATCHES
function sw(el,t){
  document.querySelectorAll('#sw-'+t+' .sw').forEach(e=>e.classList.remove('on'));
  el.classList.add('on');C[t]=new THREE.Color(el.dataset.c);buildChar();
}
function rebuild(){buildChar();}
buildChar();
</script>

<!-- ══════════════════ UI LOGIC ══════════════════ -->
<script>
const PM={
  none:{icon:'⚖️',name:'Indépendant',color:'#888'},
  'far-left':{icon:'🔴',name:'Front Révolutionnaire',color:'#cc2200'},
  left:{icon:'🌹',name:'Parti Socialiste Uni',color:'#cc4477'},
  green:{icon:'🌿',name:'Mouvement Écologiste',color:'#2a8a2a'},
  'center-left':{icon:'🕊️',name:'Alliance Progressiste',color:'#4488cc'},
  center:{icon:'⚖️',name:'Parti du Centre',color:'#c9a84c'},
  'center-right':{icon:'🏛️',name:'Union Républicaine',color:'#6688aa'},
  right:{icon:'🦅',name:'Rassemblement Nat.-Conservateur',color:'#4466aa'},
  'far-right':{icon:'⚔️',name:'Mouvement Souverainiste',color:'#225588'},
  liberal:{icon:'💼',name:'Parti Libéral',color:'#c9a84c'},
  custom:{icon:'✦',name:'Parti Personnalisé',color:'#c9a84c'},
};
const IL=[[0,15,'Communiste'],[16,30,'Gauche Radicale'],[31,42,'Gauche'],[43,57,'Centre'],[58,69,'Droite'],[70,84,'Droite Conservatrice'],[85,100,'Nationaliste']];
const SD=[{id:'charisma',l:'CHARISME'},{id:'rhetoric',l:'RHÉTORIQUE'},{id:'strategy',l:'STRATÉGIE'},{id:'diplomacy',l:'DIPLOMATIE'},{id:'integrity',l:'INTÉGRITÉ'},{id:'influence',l:'INFLUENCE'}];
const MAX=45;
const stats=Object.fromEntries(SD.map(s=>[s.id,5]));

function renderStats(){
  document.getElementById('sui').innerHTML=SD.map(s=>`
  <div class="sr">
    <div class="sn">${s.l}</div>
    <div class="sb"><div class="sf" id="bar-${s.id}" style="width:${stats[s.id]*10}%"></div></div>
    <input type="range" min="1" max="10" value="${stats[s.id]}" style="width:75px;flex-shrink:0" oninput="onStat('${s.id}',this)">
    <div class="sv" id="sv-${s.id}">${stats[s.id]}</div>
  </div>`).join('');
  updatePts();
}
function onStat(id,el){
  const nv=+el.value,ov=stats[id];
  const tot=Object.values(stats).reduce((a,b)=>a+b,0)-ov+nv;
  if(tot>MAX){el.value=ov;return;}
  stats[id]=nv;
  document.getElementById('bar-'+id).style.width=(nv*10)+'%';
  document.getElementById('sv-'+id).textContent=nv;
  updatePts();prev();
}
function updatePts(){document.getElementById('pts').textContent=MAX-Object.values(stats).reduce((a,b)=>a+b,0);}
renderStats();

function tab(e,id){
  const p=e.currentTarget.closest('.panel');
  p.querySelectorAll('.tb').forEach(b=>b.classList.remove('on'));
  p.querySelectorAll('.tp').forEach(p=>p.classList.remove('on'));
  e.currentTarget.classList.add('on');
  document.getElementById('tab-'+id).classList.add('on');
}

function onParty(){
  const v=document.getElementById('cp2').value;
  document.getElementById('cpf').style.display=v==='custom'?'block':'none';
  prev();
}
function gpn(){
  const v=document.getElementById('cp2').value;
  if(v==='custom')return document.getElementById('cpn').value||'Parti Personnalisé';
  return PM[v]?.name||'Indépendant';
}
function ilbl(v){return (IL.find(([lo,hi])=>v>=lo&&v<=hi)||[,,,'Centre'])[2];}

function onIdeo(el){
  const p=+el.value;
  el.style.setProperty('--pct',p+'%');
  document.getElementById('itxt').textContent=ilbl(p);
  document.getElementById('ic').style.left=p+'%';
  prev();
}

function prev(){
  const nm=document.getElementById('cn').value||'Votre Personnage';
  const ti=document.getElementById('ct').value||'';
  const bi=document.getElementById('cb').value||'';
  const re=document.getElementById('cr').value;
  const ag=document.getElementById('ca').value;
  const pv=document.getElementById('cp2').value;
  const iv=+document.getElementById('ci').value;
  const pt=PM[pv]||PM.none;
  const pn=gpn();
  document.getElementById('pnm').textContent=nm;
  document.getElementById('pti').textContent=ti;
  document.getElementById('pbio').textContent=bi||'—';
  document.getElementById('preg').textContent=re?`📍 ${re}`:'📍 —';
  document.getElementById('page').textContent=ag?`🎂 ${ag}`:'🎂 —';
  document.getElementById('pbdg').innerHTML=`<span class="pb" style="color:${pt.color};border-color:${pt.color}44">${pt.icon} ${pn}</span>`;
  const pp=document.getElementById('pp');
  if(pp)pp.innerHTML=`<div style="font-family:'Courier Prime',monospace;font-size:9px;letter-spacing:3px;color:${pt.color};opacity:.65;margin-top:7px">${pt.icon} ${pn}</div>`;
  genDisc(nm,ti,bi,re,ag,iv,pn,pt.icon);
}

function sbar(v){return '█'.repeat(v)+'░'.repeat(10-v);}
function ibar(v){const p=Math.round(v/10);return '░'.repeat(p)+'█'+'░'.repeat(10-p);}

function genDisc(nm,ti,bi,re,ag,iv,pn,pi){
  const sl=SD.map(s=>`  ${s.l.padEnd(12)} ${sbar(stats[s.id])} ${stats[s.id]}/10`).join('\n');
  document.getElementById('dout').textContent=
`╔══════════════════════════════════════╗
║        FICHE DE PERSONNAGE — RP      ║
╚══════════════════════════════════════╝

👤 ${nm}
   ${ti}

${pi} ${pn}

📍 ${re||'—'}  •  🎂 ${ag||'—'}

───────────────────────────────────────
📜 BIOGRAPHIE
───────────────────────────────────────
${bi||'À rédiger...'}

───────────────────────────────────────
⚖️  IDÉOLOGIE — ${ilbl(iv)}
   GAUCHE ${ibar(iv)} DROITE

───────────────────────────────────────
📊 COMPÉTENCES
───────────────────────────────────────
${sl}

───────────────────────────────────────
Fiche générée — République RP`;
}

function copyDisc(){
  navigator.clipboard.writeText('```\n'+document.getElementById('dout').textContent+'\n```').then(()=>toast('Fiche copiée !'));
}

// ── SAVE / LOAD ──
let saved=[];
function loadSaved(){
  try{const r=localStorage.getItem('rp-chars');if(r)saved=JSON.parse(r);}catch{saved=[];}
  renderSaved();
}
function saveLocal(){
  const d=gather();
  const i=saved.findIndex(c=>c.name===d.name);
  if(i>=0)saved[i]=d;else saved.push(d);
  try{localStorage.setItem('rp-chars',JSON.stringify(saved));}catch{}
  renderSaved();toast('Sauvegardé !');
}
function renderSaved(){
  const el=document.getElementById('sl');
  if(!saved.length){el.innerHTML='<div style="font-family:\'Courier Prime\',monospace;font-size:9px;letter-spacing:3px;color:var(--gold);opacity:.25;text-align:center;padding:14px;text-transform:uppercase">Aucun personnage</div>';return;}
  el.innerHTML=saved.map((c,i)=>`
  <div class="si" onclick="loadChar(${i})">
    <div><div class="snm">${c.name||'Sans nom'}</div><div class="sti">${PM[c.party]?.icon||'⚖️'} ${c.title||'—'}</div></div>
    <button class="btn br" style="padding:3px 8px;font-size:8px;letter-spacing:1px" onclick="event.stopPropagation();delChar(${i})">✕</button>
  </div>`).join('');
}
function loadChar(i){
  const c=saved[i];
  document.getElementById('cn').value=c.name||'';
  document.getElementById('ct').value=c.title||'';
  document.getElementById('cb').value=c.bio||'';
  document.getElementById('cr').value=c.region||'';
  document.getElementById('ca').value=c.age||'';
  document.getElementById('cp2').value=c.party||'none';
  document.getElementById('cpn').value=c.party_name||'';
  document.getElementById('ci').value=c.ideology||50;
  document.getElementById('cbuild').value=c.build||'average';
  document.getElementById('cacc').value=c.accessory||'none';
  onParty();
  if(c.colors)Object.entries(c.colors).forEach(([k,v])=>{
    C[k]=new THREE.Color(v);
    const el=document.querySelector(`#sw-${k} .sw[data-c="${v}"]`);
    if(el){document.querySelectorAll(`#sw-${k} .sw`).forEach(e=>e.classList.remove('on'));el.classList.add('on');}
  });
  if(c.stats)Object.entries(c.stats).forEach(([k,v])=>{if(stats[k]!==undefined)stats[k]=v;});
  renderStats();rebuild();
  const el=document.getElementById('ci');onIdeo(el);prev();
  toast('Personnage chargé !');
}
function delChar(i){saved.splice(i,1);try{localStorage.setItem('rp-chars',JSON.stringify(saved));}catch{}renderSaved();}
function gather(){
  return{
    name:document.getElementById('cn').value,title:document.getElementById('ct').value,
    bio:document.getElementById('cb').value,region:document.getElementById('cr').value,
    age:document.getElementById('ca').value,party:document.getElementById('cp2').value,
    party_name:document.getElementById('cpn').value,ideology:+document.getElementById('ci').value,
    build:document.getElementById('cbuild').value,accessory:document.getElementById('cacc').value,
    stats:{...stats},
    colors:Object.fromEntries(Object.entries(C).map(([k,v])=>[k,'#'+v.getHexString()])),
  };
}
function expJSON(){
  const d=gather();
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(d,null,2)],{type:'application/json'}));
  a.download=(d.name||'personnage').replace(/\s+/g,'_')+'.json';a.click();toast('Exporté !');
}
function impJSON(e){
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{try{const d=JSON.parse(ev.target.result);saved.push(d);try{localStorage.setItem('rp-chars',JSON.stringify(saved));}catch{}renderSaved();loadChar(saved.length-1);}catch{toast('JSON invalide !');}};
  r.readAsText(f);
}

// ── SERVER SAVE ──
const TOK='{{ token }}';
if(TOK&&TOK!=='None')document.getElementById('ssp').style.display='block';
async function saveServer(){
  const d=gather();
  try{
    const res=await fetch('/api/save',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({token:TOK,character:d})});
    const j=await res.json();
    if(j.ok)toast('✅ Sauvegardé sur Discord !');else toast('Erreur : '+j.error);
  }catch{toast('Erreur réseau');}
}

// ── PRE-LOAD EXISTING CHAR ──
const EC={{ char|safe if char else 'null' }};
if(EC){setTimeout(()=>{saved.push(EC);loadChar(saved.length-1);},300);}

// ── INIT ──
loadSaved();prev();
onIdeo(document.getElementById('ci'));
</script>
</body>
</html>
